def create_monster_card(monster):
    """Create elements for a single monster card"""
    story = []
    
    # Styles
    styles = getSampleStyleSheet()
    
    title_style = ParagraphStyle(
        'MonsterTitle',
        parent=styles['Heading1'],
        fontSize=20,
        textColor=colors.HexColor('#8B0000'),
        alignment=TA_CENTER,
        spaceAfter=6,
        fontName='Helvetica-Bold'
    )
    
    type_style = ParagraphStyle(
        'MonsterType',
        parent=styles['Normal'],
        fontSize=10,
        alignment=TA_CENTER,
        textColor=colors.grey,
        fontName='Helvetica-Oblique',
        spaceAfter=12
    )
    
    stat_style = ParagraphStyle(
        'Stat',
        parent=styles['Normal'],
        fontSize=11,
        spaceAfter=6
    )
    
    header_style = ParagraphStyle(
        'SectionHeader',
        parent=styles['Heading2'],
        fontSize=12,
        textColor=colors.HexColor('#8B0000'),
        fontName='Helvetica-Bold',
        spaceBefore=8,
        spaceAfter=6
    )
    
    ability_style = ParagraphStyle(
        'Ability',
        parent=styles['Normal'],
        fontSize=10,
        leftIndent=20,
        spaceAfter=4,
        bulletIndent=10
    )
    
    # Title
    story.append(Paragraph(monster['name'], title_style))
    
    # Horizontal line
    story.append(Table([['']], colWidths=[6.5*inch], style=[
        ('LINEBELOW', (0,0), (-1,-1), 2, colors.HexColor('#8B0000'))
    ]))
    story.append(Spacer(1, 6))
    
    # Type
    story.append(Paragraph(monster['type'], type_style))
    
    # Stats
    story.append(Paragraph(f"<b>Hit Points:</b> {monster['hp']}", stat_style))
    story.append(Paragraph(f"<b>Armor Class:</b> {monster['ac']}", stat_style))
    story.append(Spacer(1, 6))
    
    # Abilities
    if monster['abilities']:
        story.append(Paragraph("SPECIAL ABILITIES", header_style))
        for ability in monster['abilities']:
            story.append(Paragraph(f"• {ability}", ability_style))
    
    # Attacks
    if monster['attacks']:
        story.append(Paragraph("ATTACKS", header_style))
        for attack in monster['attacks']:
            story.append(Paragraph(f"• {attack}", ability_style))
    
    return story

# Create PDF
output_path = '/Users/moon/MoveAlong/dnd_monster_cards.pdf'
doc = SimpleDocTemplate(
    output_path,
    pagesize=letter,
    topMargin=0.5*inch,
    bottomMargin=0.5*inch,
    leftMargin=0.75*inch,
    rightMargin=0.75*inch
)

story = []

for i, monster in enumerate(monsters):
    # Add monster card
    card_elements = create_monster_card(monster)
    story.extend(card_elements)
    
    # Add separator or page break
    if i % 2 == 0 and i < len(monsters) - 1:
        # Add separator between cards on same page
        story.append(Spacer(1, 0.25*inch))
        story.append(Table([['─' * 80]], colWidths=[6.5*inch], style=[
            ('ALIGN', (0,0), (-1,-1), 'CENTER'),
            ('TEXTCOLOR', (0,0), (-1,-1), colors.grey)
        ]))
        story.append(Spacer(1, 0.25*inch))
    elif i % 2 == 1 and i < len(monsters) - 1:
        # Page break after second card
        story.append(PageBreak())

# Build PDF
doc.build(story)
print(f"PDF created successfully at {output_path}")
